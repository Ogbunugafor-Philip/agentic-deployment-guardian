# Copy to .env on the server to override the defaults baked into docker-compose.yml.
# The .env file is gitignored and never committed.

# PostgreSQL (Guardian's own Dockerized instance)
POSTGRES_USER=guardian
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=guardian

# Application
ENVIRONMENT=production

# Shared secret for validating GitHub webhook signatures (HMAC-SHA256).
# Sourced from the WEBHOOK_SECRET repository secret (GitHub reserves the GITHUB_
# prefix for secret names) and used by the notify-guardian workflow to sign
# outgoing failure events. The pipeline writes this value on every deploy.
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

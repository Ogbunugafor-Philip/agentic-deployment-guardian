# Copy to .env on the server to override the defaults baked into docker-compose.yml.
# The .env file is gitignored and never committed.

# PostgreSQL (Guardian's own Dockerized instance)
POSTGRES_USER=guardian
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=guardian

# Application
ENVIRONMENT=production

# Shared secret for validating GitHub webhook signatures (HMAC-SHA256).
# Sourced from the WEBHOOK_SECRET repository secret (GitHub reserves the GITHUB_
# prefix for secret names) and used by the notify-guardian workflow to sign
# outgoing failure events. The pipeline writes this value on every deploy.
GITHUB_WEBHOOK_SECRET=change-me-to-a-long-random-string

# GitHub Personal Access Token used to pull Actions job logs via the REST API.
# Sourced from the GH_PAT repository secret; written to .env on every deploy.
# Needs read access to Actions logs for this repo (classic: 'repo' scope, or a
# fine-grained token with Actions: Read + Contents: Read). Never logged/stored.
GH_PAT=ghp_your_personal_access_token

# Cerebras API key for AI root-cause analysis (model: gpt-oss-120b).
# Sourced from the CEREBRAS_API_KEY repository secret; written to .env on every
# deploy. Never logged or stored in the database.
CEREBRAS_API_KEY=csk-your_cerebras_api_key

# --- Phase 6: autonomous remediation ---
# Master switch (SERVICE_RESTART). When false, restart is dry-run.
REMEDIATION_ENABLED=true
# Gate the real revert-and-push for AUTO_ROLLBACK. Dry-run when false.
# (Set repo Variable REMEDIATION_ROLLBACK_ENABLED=true to enable live rollback;
#  a write-scoped GH_PAT is then required.)
REMEDIATION_ROLLBACK_ENABLED=false
# Health endpoint polled to confirm recovery (app service over the compose net).
HEALTH_CHECK_URL=http://app:8100/health
# SSH target for SERVICE_RESTART. VPS_SSH_KEY_B64 is the base64 of the private
# key (single line so it fits in .env); sourced from the VPS_SSH_KEY secret.
# Never logged or stored in the database.
VPS_HOST=your.vps.ip
VPS_USER=guardian
VPS_SSH_KEY_B64=base64_of_private_key

# --- Phase 7: Gmail incident reporting ---
# App password sourced from the GMAIL_APP_PASSWORD repository secret; written to
# .env on every deploy. Never logged. FROM/TO are written as literals.
GMAIL_APP_PASSWORD=your_gmail_app_password
GMAIL_FROM=philiposita1041@gmail.com
GMAIL_TO=philiposita1041@gmail.com

# --- Phase 9: hardening ---
# JWT auth for management endpoints + AES-256 encryption-at-rest key.
# The pipeline auto-generates JWT_SECRET, API_PASSWORD and GUARDIAN_ENC_KEY on
# first deploy and preserves them across deploys. Never logged.
JWT_SECRET=auto_generated_32_byte_hex
API_USER=guardian
API_PASSWORD=auto_generated_password
GUARDIAN_ENC_KEY=auto_generated_32_byte_hex
